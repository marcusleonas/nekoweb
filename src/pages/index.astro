---
import "~/styles/reset.css";
import "~/styles/style.css";

import Head from "~/components/global/head.astro";
import NameSetter from "~/components/name-setter.svelte";
---

<html lang="en">
  <head>
    <Head />
  </head>
  <body>
    <div class="wrapper">
      <img
        src="/pics/umbrella-logo.png"
        alt="umbrella logo"
        style="margin: 0 auto;"
      />
      <div class="container">
        <div class="container-title">
          <p>WARNING - PLEASE READ</p>
        </div>
        <div class="content">
          <h1>This website has been seised by the Umbrella Corporation.</h1>
          <p>
            <strong>WARNING:</strong> Proceed with caution. The following site contains
            content that may be hazardous to certain individuals. Identified biohazards
            include:
          </p>
          <ul>
            <li>Swearing</li>
            <li>Over-sharing</li>
            <li>Venting</li>
            <li>Bad Code</li>
          </ul>
          <p>
            Umbrella Corporation assumes no liability for psychological or
            emotional damage sustained beyond this point. By proceeding, you
            acknowledge these risks and accept full responsibility for your
            continued exposure.
          </p>
          <h2>Please enter your details below to enter.</h2>
          <NameSetter client:load />
          <small
            ><em
              >(Note: This is stored as a cookie and used throughout the site.
              No data is sent to a server.)</em
            ></small
          >
        </div>
      </div>
      <footer class="footer">
        <div class="marquee">
          <p>
            (c) 2022-2026 || Licensed under <a
              href="https://creativecommons.org/licenses/by-nd/4.0/">CC BY-ND</a
            > || <a href="https://github.com/marcusleonas/nekoweb"
              >View Source</a
            >
          </p>
          <p>
            Hosted on <a href="https://nekoweb.org">Nekoweb</a>, built with <a
              href="https://astro.build">Astro</a
            >, made with &hearts;.
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
