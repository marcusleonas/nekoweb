---
const links: Link[] = [
  {
    title: "Home",
    href: "/home",
  },
  {
    title: "About",
    href: "/about",
  },
  {
    title: "Blog",
    href: "/blog",
  },
  {
    title: "Resources",
    href: "/resources",
  },
  {
    title: "Outgoing",
    sublinks: [
      {
        title: "Links",
        href: "/links",
      },
      {
        title: "Guestbook",
        href: "https://wishbone.atabook.org",
      },
      {
        title: "Follow on Nekoweb",
        href: "https://nekoweb.org/follow/n3bula.lol",
      },
    ],
  },
];

interface BaseLink {
  title: string;
}

interface LinkItem extends BaseLink {
  href: string;
}

interface LinkGroup extends BaseLink {
  sublinks: LinkItem[];
}

type Link = LinkItem | LinkGroup;
---

<aside class="side">
  <div class="container">
    <div class="container-title">
      <p>navigation</p>
    </div>
    <div class="content">
      <div class="links">
        {
          links.map((link) =>
            "sublinks" in link ? (
              <details>
                <summary>{link.title}</summary>
                <div class="sub-links">
                  {link.sublinks.map((sublink) => (
                    <a href={sublink.href} class="link">
                      {sublink.title}
                    </a>
                  ))}
                </div>
              </details>
            ) : (
              <a href={link.href} class="link">
                {link.title}
              </a>
            ),
          )
        }
      </div>
    </div>
  </div>

  <div class="container">
    <div class="container-title"><p>todo</p></div>
    <div class="content">
      <ul class="ls-none">
        <li>add blinkies page</li>
        <li>actually finish the site....</li>
      </ul>
    </div>
  </div>
</aside>
